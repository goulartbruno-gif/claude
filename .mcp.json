{
  "mcpServers": {
    "notebooklm": {
      "command": "uv",
      "args": ["run", "python", "server.py"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    },
    "obsidian-dispatch": {
      "command": "uv",
      "args": ["run", "python", "server.py"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}/obsidian-dispatch-mcp",
      "env": {
        "OBSIDIAN_VAULT_PATH": "${OBSIDIAN_VAULT_PATH}"
      }
    },
    "claude-flow": {
      "command": "npx",
      "args": ["-y", "ruflo@latest", "mcp", "start"]
    }
  }
}
